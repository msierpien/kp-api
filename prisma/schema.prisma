// ============================================
// MODUŁ MAGAZYNOWY
// ============================================

enum WarehouseDocumentType {
  PZ  // Przyjęcie Zewnętrzne (od dostawcy)
  ZH  // Zamówienie Hurtowe (zamówione u dostawcy, bez wpływu na stan)
  PW  // Przyjęcie Wewnętrzne (np. z produkcji)
  WZ  // Wydanie Zewnętrzne (do klienta)
  ZW  // Zwrot od klienta
  RW  // Rozchód Wewnętrzny (zużycie)
  INW // Inwentaryzacja (korekta stanu na bazie spisu)
}

enum WarehouseDocumentStatus {
  DRAFT // Roboczy — nie wpływa na stany
  CONFIRMED // Zatwierdzony — wpływa na stany
  CANCELLED // Anulowany
}

enum WarehouseReservationStatus {
  ACTIVE
  CONSUMED
  RELEASED
  CANCELLED
}

enum WarehouseReservationSource {
  LOCAL_STOCK
  WHOLESALE_BACKORDER
}

enum OrderItemSourceType {
  SIMPLE
  BUNDLE_COMPONENT
}

enum WholesalePlatform {
  CSV_FEED
  XML_FEED
  REST_API
}

