{
  "name": "personalization-api",
  "version": "1.3.1",
  "description": "PrestaShop personalization API with Fastify",
  "main": "dist/index.js",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:api": "RUNTIME_ROLE=api tsx watch src/index.ts",
    "dev:worker": "RUNTIME_ROLE=worker tsx watch src/index.ts",
    "dev:scheduler": "RUNTIME_ROLE=scheduler tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "start:api": "RUNTIME_ROLE=api node dist/index.js",
    "start:worker": "RUNTIME_ROLE=worker node dist/index.js",
    "start:scheduler": "RUNTIME_ROLE=scheduler node dist/index.js",
    "start:dev": "tsx watch src/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "load:test": "tsx scripts/load-test.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"tests/**/*.test.ts\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "fastify",
    "typescript",
    "prestashop",
    "personalization"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@bull-board/api": "^6.16.4",
    "@bull-board/fastify": "^6.16.4",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/request-context": "^6.2.1",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@prisma/client": "^5.8.1",
    "@types/pdfkit": "^0.17.4",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.67.1",
    "canvas": "^3.2.1",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.3.1",
    "fabric": "^7.1.0",
    "fastify": "^5.7.2",
    "fastify-plugin": "^5.1.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.3.2",
    "mime-types": "^3.0.2",
    "nanoid": "^5.0.4",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "opentype.js": "^1.3.4",
    "p-queue": "^9.1.0",
    "pdfkit": "^0.17.2",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.11",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.9",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prisma": "^5.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
