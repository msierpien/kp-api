// Prisma Schema dla systemu personalizacji PrestaShop
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Multi-tenant
// ============================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model Tenant {
  id           String       @id @default(cuid())
  name         String // np. "Kreatywne Papierki"
  slug         String       @unique // np. "kreatywne-papierki"
  status       TenantStatus @default(ACTIVE)
  plan         String       @default("FREE") // FREE, BASIC, PRO, ENTERPRISE
  limitsJson   Json?        @map("limits_json") // { max_shops: 5, max_users: 10, max_cases_per_month: 1000 }
  featuresJson Json?        @map("features_json") // { personalization_editor: true }
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  users                 User[]
  authSessions          AuthSession[]
  automations           Automation[]
  shops                 Shop[]
  templates             PersonalizationTemplate[]
  emailSettings         EmailSettings[]
  aiSettings            AiSettings?
  aiPromptTemplates     AiPromptTemplate[]
  aiUsageLogs           AiUsageLog[]
  aiBulkContentJobs     AiBulkContentJob[]
  aiBulkContentJobItems AiBulkContentJobItem[]
  warehouseProducts     WarehouseProduct[]
  warehouseCatalogs     WarehouseCatalog[]
  warehouseLeadTimeGroups WarehouseLeadTimeGroup[]
  warehouseDocuments    WarehouseDocument[]
  warehouseBarcodes     WarehouseProductBarcode[]
  shopProductMappings   ShopProductMapping[]
  stockSyncLogs         StockSyncLog[]
  priceSyncLogs         PriceSyncLog[]
  pricingRules          WarehousePricingRule[]
  priceGroups           WarehousePriceGroup[]
  priceGroupMembers     WarehousePriceGroupMember[]
  pricingSettings       WarehousePricingSettings?
  productShopPrices     WarehouseProductShopPrice[]
  shopProductImportLogs ShopProductImportLog[]
  wholesaleProviders    WholesaleProvider[]
  wholesaleMappings     WholesaleProductMapping[]
  wholesaleSyncLogs     WholesaleSyncLog[]
  warehouseReservations WarehouseReservation[]
  shopOrderStatuses     ShopOrderStatus[]
  ifirmaSettings        IfirmaSettings[]
  salesDocuments        SalesDocument[]
  orderReturns          OrderReturn[]
  orderReturnItems      OrderReturnItem[]
  invoiceEmailLogs      InvoiceEmailLog[]
  productChannelSnapshots ProductChannelSnapshot[]
  productChannelSyncConfigs ProductChannelSyncConfig[]
  productCardOperationLogs ProductCardOperationLog[]

  @@index([status])
  @@index([slug])
  @@map("tenants")
}

// ============================================
// Integracja / Sklepy
// ============================================

enum ShopPlatform {
  PRESTASHOP
  WOOCOMMERCE
  SHOPIFY
  MAGENTO
  MANUAL // Ręczne zamówienia (FB, Instagram, email)
  CUSTOM_API // Niestandardowe integracje API
  OTHER
}

enum IdentifierType {
  SKU // reference w PrestaShop
  INDEX // supplier_reference w PrestaShop
  EAN // ean13 w PrestaShop
}

model Shop {
  id           String       @id @default(cuid())
  tenantId     String       @map("tenant_id")
  name         String
  platform     ShopPlatform @default(PRESTASHOP)
  baseUrl      String       @map("base_url")
  apiKey       String       @default("") @map("api_key") // zaszyfrowane
  apiSecret    String?      @map("api_secret") // zaszyfrowane, opcjonalne
  status       String       @default("ACTIVE") // ACTIVE, INACTIVE
  lastSyncAt   DateTime?    @map("last_sync_at")
  syncInterval Int          @default(30) @map("sync_interval") // interwał synchronizacji w minutach
  syncEnabled  Boolean      @default(true) @map("sync_enabled") // czy auto-sync jest włączony
  configJson   Json?        @map("config_json") // dodatkowa konfiguracja specyficzna dla platformy
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  tenant               Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders               Order[]
  syncLogs             SyncLog[]
  personalizedProducts PersonalizedProduct[]
  productMappings      ShopProductMapping[]
  stockSyncLogs        StockSyncLog[]
  priceSyncLogs        PriceSyncLog[]
  pricingRules         WarehousePricingRule[]
  productShopPrices    WarehouseProductShopPrice[]
  productImportLogs    ShopProductImportLog[]
  productChannelSnapshots ProductChannelSnapshot[]
  productChannelSyncConfigs ProductChannelSyncConfig[]
  productCardOperationLogs ProductCardOperationLog[]
  webhookEvents        ShopWebhookEvent[]
  orderStatuses        ShopOrderStatus[]
  ifirmaSettings       IfirmaSettings?
  salesDocuments       SalesDocument[]
  orderReturns         OrderReturn[]

  @@index([tenantId])
  @@index([status])
  @@index([platform])
  @@index([syncEnabled])
  @@map("shops")
}

model PersonalizedProduct {
  id                String         @id @default(cuid())
  shopId            String         @map("shop_id")
  name              String // nazwa produktu dla łatwej identyfikacji
  identifierType    IdentifierType @default(SKU) @map("identifier_type") // SKU, INDEX, EAN
  identifierValue   String         @map("identifier_value") // wartość identyfikatora (np. "INV-KOMUNIA-001")
  externalProductId String?        @map("external_product_id") // ID produktu w PrestaShop (opcjonalne)
  templateId        String         @map("template_id")
  isActive          Boolean        @default(true) @map("is_active")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  shop       Shop                    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  template   PersonalizationTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]

  @@unique([shopId, identifierType, identifierValue])
  @@index([shopId])
  @@index([identifierValue])
  @@index([isActive])
  @@map("personalized_products")
}

// ============================================
// Zamówienia
// ============================================

model Order {
  id              String   @id @default(cuid())
  shopId          String   @map("shop_id")
  externalOrderId String   @map("external_order_id") // ID zamówienia w sklepie
  orderReference  String   @map("order_reference")
  customerEmail   String   @map("customer_email")
  customerName    String?  @map("customer_name")
  language        String   @default("pl")
  currency        String   @default("PLN")
  totalPaid       Decimal  @map("total_paid") @db.Decimal(10, 2)
  totalShippingTaxIncl Decimal? @map("total_shipping_tax_incl") @db.Decimal(10, 2)
  totalShippingTaxExcl Decimal? @map("total_shipping_tax_excl") @db.Decimal(10, 2)
  totalDiscountsTaxIncl Decimal? @map("total_discounts_tax_incl") @db.Decimal(10, 2)
  totalDiscountsTaxExcl Decimal? @map("total_discounts_tax_excl") @db.Decimal(10, 2)
  paymentMethod  String?  @map("payment_method")
  operationalStatus String @default("NEW") @map("operational_status")
  externalStatusId String? @map("external_status_id")
  externalStatusName String? @map("external_status_name")
  statusSyncedAt DateTime? @map("status_synced_at")
  statusSyncError String? @map("status_sync_error") @db.Text
  createdAtShop   DateTime @map("created_at_shop")
  payloadJson     Json     @map("payload_json") // snapshot całego zamówienia z API sklepu
  billingAddressJson Json? @map("billing_address_json")
  deliveryAddressJson Json? @map("delivery_address_json")
  maxShippingDate DateTime? @map("max_shipping_date")
  shippingPromiseLabel String? @map("shipping_promise_label")
  shippingCutoffUsedAt DateTime? @map("shipping_cutoff_used_at")
  syncedAt        DateTime @default(now()) @map("synced_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  shop                  Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items                 OrderItem[]
  personalizationCases  PersonalizationCase[]
  accessPins            OrderAccessPin[]
  warehouseDocuments    WarehouseDocument[]
  warehouseReservations WarehouseReservation[]
  salesDocuments        SalesDocument[]
  returns               OrderReturn[]

  @@unique([shopId, externalOrderId])
  @@index([shopId, orderReference])
  @@index([shopId, operationalStatus])
  @@index([shopId, externalStatusId])
  @@index([shopId, createdAtShop])
  @@index([shopId, maxShippingDate])
  @@index([customerEmail])
  @@map("orders")
}

model OrderItem {
  id                    String   @id @default(cuid())
  orderId               String   @map("order_id")
  externalItemId        String   @map("external_item_id") // ID pozycji w sklepie
  sku                   String
  productNameSnapshot   String   @map("product_name_snapshot")
  quantity              Int
  unitPriceTaxIncl      Decimal? @map("unit_price_tax_incl") @db.Decimal(10, 2)
  unitPriceTaxExcl      Decimal? @map("unit_price_tax_excl") @db.Decimal(10, 2)
  totalPriceTaxIncl     Decimal? @map("total_price_tax_incl") @db.Decimal(10, 2)
  totalPriceTaxExcl     Decimal? @map("total_price_tax_excl") @db.Decimal(10, 2)
  taxRate               Decimal? @map("tax_rate") @db.Decimal(5, 4)
  taxName               String?  @map("tax_name")
  personalizedProductId String?  @map("personalized_product_id")
  warehouseProductId    String?  @map("warehouse_product_id")
  sourceType            OrderItemSourceType @default(SIMPLE) @map("source_type")
  bundleGroupId         String?  @map("bundle_group_id")
  bundleName            String?  @map("bundle_name")
  bundleExternalItemId  String?  @map("bundle_external_item_id")
  bundleExternalProductId String? @map("bundle_external_product_id")
  shippingDate          DateTime? @map("shipping_date")
  shippingLeadTimeDays  Int?     @map("shipping_lead_time_days")
  shippingSource        String?  @map("shipping_source")
  payloadJson           Json?    @map("payload_json")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  order                 Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  personalizedProduct   PersonalizedProduct?   @relation(fields: [personalizedProductId], references: [id], onDelete: SetNull)
  warehouseProduct      WarehouseProduct?      @relation(fields: [warehouseProductId], references: [id], onDelete: SetNull)
  personalizationCase   PersonalizationCase?
  warehouseReservations WarehouseReservation[]
  returnItems           OrderReturnItem[]

  @@index([orderId])
  @@index([sku])
  @@index([personalizedProductId])
  @@index([warehouseProductId])
  @@index([sourceType])
  @@index([bundleGroupId])
  @@map("order_items")
}

// ============================================
// Synchronizacja / Logi
// ============================================

model SyncLog {
  id            String    @id @default(cuid())
  shopId        String    @map("shop_id")
  syncType      String    @map("sync_type") // ORDERS, PRODUCTS
  status        String    @default("SUCCESS") // SUCCESS, FAILED, PARTIAL
  ordersFetched Int       @default(0) @map("orders_fetched")
  ordersCreated Int       @default(0) @map("orders_created")
  ordersSkipped Int       @default(0) @map("orders_skipped")
  errorMessage  String?   @map("error_message") @db.Text
  startedAt     DateTime  @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([startedAt])
  @@index([status])
  @@map("sync_logs")
}

model ShopWebhookEvent {
  id                String    @id @default(cuid())
  shopId            String    @map("shop_id")
  eventKey          String    @unique @map("event_key")
  eventType         String    @map("event_type")
  externalOrderId   String    @map("external_order_id")
  prestashopShopId  String?   @map("prestashop_shop_id")
  orderStatusId     String    @map("order_status_id")
  orderStatusName   String?   @map("order_status_name")
  status            String    @default("PENDING")
  payloadHash       String    @map("payload_hash")
  payloadJson       Json      @map("payload_json")
  errorMessage      String?   @map("error_message") @db.Text
  receivedAt        DateTime  @default(now()) @map("received_at")
  processedAt       DateTime? @map("processed_at")
  failedAt          DateTime? @map("failed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, receivedAt])
  @@index([shopId, status])
  @@index([eventType])
  @@index([externalOrderId])
  @@map("shop_webhook_events")
}

model ShopOrderStatus {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  shopId            String    @map("shop_id")
  externalStatusId  String    @map("external_status_id")
  name              String
  color             String?
  operationalStatus String?   @map("operational_status")
  isPaid            Boolean   @default(false) @map("is_paid")
  isCancelled       Boolean   @default(false) @map("is_cancelled")
  isReadyForInvoice Boolean   @default(false) @map("is_ready_for_invoice")
  isInvoiceTarget   Boolean   @default(false) @map("is_invoice_target")
  sortOrder         Int       @default(0) @map("sort_order")
  payloadJson       Json?     @map("payload_json")
  lastSyncedAt      DateTime? @map("last_synced_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, externalStatusId])
  @@index([tenantId])
  @@index([shopId])
  @@index([tenantId, operationalStatus])
  @@index([tenantId, isReadyForInvoice])
  @@map("shop_order_statuses")
}

enum SalesDocumentType {
  INVOICE
  CORRECTION
}

enum SalesDocumentStatus {
  DRAFT
  PENDING
  ISSUED
  SENT
  FAILED
  CANCELLED
}

model IfirmaSettings {
  id                    String   @id @default(cuid())
  tenantId              String   @map("tenant_id")
  shopId                String   @unique @map("shop_id")
  login                 String
  invoiceKey            String   @map("invoice_key")
  mode                  String   @default("production")
  isActive              Boolean  @default(true) @map("is_active")
  defaultPaymentMethod  String   @default("PRZ") @map("default_payment_method")
  paymentTermDays       Int      @default(0) @map("payment_term_days")
  numberingSeriesName   String?  @map("numbering_series_name")
  templateName          String?  @map("template_name")
  issuePlace            String?  @map("issue_place")
  bankAccountNumber     String?  @map("bank_account_number")
  receiverSignatureType String   @default("BPO") @map("receiver_signature_type")
  receiverSignature     String?  @map("receiver_signature")
  issuerSignature       String?  @map("issuer_signature")
  visibleBdo            Boolean  @default(false) @map("visible_bdo")
  sendEmailAfterIssue   Boolean  @default(false) @map("send_email_after_issue")
  splitBundleItems      Boolean  @default(false) @map("split_bundle_items")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([shopId])
  @@map("ifirma_settings")
}

model SalesDocument {
  id                  String              @id @default(cuid())
  tenantId            String              @map("tenant_id")
  shopId              String              @map("shop_id")
  orderId             String              @map("order_id")
  externalOrderId     String              @map("external_order_id")
  documentType        SalesDocumentType   @default(INVOICE) @map("document_type")
  documentKey         String              @default("PRIMARY") @map("document_key")
  status              SalesDocumentStatus @default(DRAFT)
  parentDocumentId    String?             @map("parent_document_id")
  orderReturnId       String?             @unique @map("order_return_id")
  externalId          String?             @map("external_id")
  externalNumber      String?             @map("external_number")
  requestPayloadJson  Json?               @map("request_payload_json")
  responsePayloadJson Json?               @map("response_payload_json")
  pdfUrl              String?             @map("pdf_url")
  pdfPath             String?             @map("pdf_path")
  issuedAt            DateTime?           @map("issued_at")
  sentAt              DateTime?           @map("sent_at")
  failedAt            DateTime?           @map("failed_at")
  errorMessage        String?             @map("error_message") @db.Text
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop      Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  parentDocument SalesDocument? @relation("SalesDocumentCorrections", fields: [parentDocumentId], references: [id], onDelete: SetNull)
  corrections     SalesDocument[] @relation("SalesDocumentCorrections")
  orderReturn     OrderReturn? @relation(fields: [orderReturnId], references: [id], onDelete: SetNull)
  emailLogs InvoiceEmailLog[]

  @@unique([shopId, externalOrderId, documentType, documentKey])
  @@index([tenantId])
  @@index([shopId])
  @@index([orderId])
  @@index([parentDocumentId])
  @@index([orderReturnId])
  @@index([status])
  @@map("sales_documents")
}

enum OrderReturnType {
  CANCELLATION
  RETURN
}

enum OrderReturnStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model OrderReturn {
  id                         String            @id @default(cuid())
  tenantId                   String            @map("tenant_id")
  shopId                     String            @map("shop_id")
  orderId                    String            @map("order_id")
  externalOrderId            String            @map("external_order_id")
  type                       OrderReturnType
  status                     OrderReturnStatus @default(PENDING)
  reason                     String?           @db.Text
  refundShipping             Boolean           @default(false) @map("refund_shipping")
  restockItems               Boolean           @default(true) @map("restock_items")
  autoConfirmWarehouseDocument Boolean          @default(true) @map("auto_confirm_warehouse_document")
  totalRefundTaxIncl         Decimal           @default(0) @map("total_refund_tax_incl") @db.Decimal(10, 2)
  totalRefundTaxExcl         Decimal           @default(0) @map("total_refund_tax_excl") @db.Decimal(10, 2)
  shippingRefundTaxIncl      Decimal           @default(0) @map("shipping_refund_tax_incl") @db.Decimal(10, 2)
  shippingRefundTaxExcl      Decimal           @default(0) @map("shipping_refund_tax_excl") @db.Decimal(10, 2)
  externalStatusId           String?           @map("external_status_id")
  externalStatusName         String?           @map("external_status_name")
  warehouseDocumentId        String?           @unique @map("warehouse_document_id")
  ifirmaStatus               String?           @map("ifirma_status")
  ifirmaRequestPayloadJson   Json?             @map("ifirma_request_payload_json")
  ifirmaResponsePayloadJson  Json?             @map("ifirma_response_payload_json")
  ifirmaErrorMessage         String?           @map("ifirma_error_message") @db.Text
  prestashopStatus           String?           @map("prestashop_status")
  prestashopOrderSlipId      String?           @map("prestashop_order_slip_id")
  prestashopRequestPayloadJson Json?           @map("prestashop_request_payload_json")
  prestashopResponsePayloadJson Json?          @map("prestashop_response_payload_json")
  prestashopErrorMessage     String?           @map("prestashop_error_message") @db.Text
  errorMessage               String?           @map("error_message") @db.Text
  completedAt                DateTime?         @map("completed_at")
  failedAt                   DateTime?         @map("failed_at")
  createdAt                  DateTime          @default(now()) @map("created_at")
  updatedAt                  DateTime          @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop              Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  warehouseDocument WarehouseDocument? @relation(fields: [warehouseDocumentId], references: [id], onDelete: SetNull)
  items             OrderReturnItem[]
  salesDocument     SalesDocument?

  @@index([tenantId])
  @@index([shopId])
  @@index([orderId])
  @@index([status])
  @@index([type])
  @@map("order_returns")
}

model OrderReturnItem {
  id                    String   @id @default(cuid())
  tenantId              String   @map("tenant_id")
  orderReturnId         String   @map("order_return_id")
  orderItemId           String   @map("order_item_id")
  externalItemId        String   @map("external_item_id")
  sku                   String
  productNameSnapshot   String   @map("product_name_snapshot")
  quantity              Decimal  @db.Decimal(10, 3)
  unitPriceTaxIncl      Decimal? @map("unit_price_tax_incl") @db.Decimal(10, 2)
  unitPriceTaxExcl      Decimal? @map("unit_price_tax_excl") @db.Decimal(10, 2)
  totalRefundTaxIncl    Decimal  @default(0) @map("total_refund_tax_incl") @db.Decimal(10, 2)
  totalRefundTaxExcl    Decimal  @default(0) @map("total_refund_tax_excl") @db.Decimal(10, 2)
  taxRate               Decimal? @map("tax_rate") @db.Decimal(5, 4)
  warehouseProductId    String?  @map("warehouse_product_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderReturn OrderReturn     @relation(fields: [orderReturnId], references: [id], onDelete: Cascade)
  orderItem   OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([orderReturnId])
  @@index([orderItemId])
  @@index([warehouseProductId])
  @@map("order_return_items")
}

model InvoiceEmailLog {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  salesDocumentId   String    @map("sales_document_id")
  toEmail           String    @map("to_email")
  subject           String
  status            String    @default("PENDING")
  providerMessageId String?   @map("provider_message_id")
  payloadJson       Json?     @map("payload_json")
  errorMessage      String?   @map("error_message") @db.Text
  sentAt            DateTime? @map("sent_at")
  failedAt          DateTime? @map("failed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesDocument SalesDocument @relation(fields: [salesDocumentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([salesDocumentId])
  @@index([status])
  @@map("invoice_email_logs")
}

// ============================================
// Konfiguracja personalizacji
// ============================================

model PersonalizationTemplate {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  code         String // np. INV_KOMUNIA_01 (unique per tenant)
  name         String
  description  String?
  version      Int      @default(1)
  isActive     Boolean  @default(true) @map("is_active")
  layoutJson   Json?    @map("layout_json") // TemplateLayoutJson - pozycje pól, warstwy, czcionki
  thumbnailUrl String?  @map("thumbnail_url") // URL miniatury szablonu
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  forms                Form[]
  cases                PersonalizationCase[]
  personalizedProducts PersonalizedProduct[]
  templateAssets       TemplateAsset[]
  shopProductMappings  ShopProductMapping[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([code])
  @@index([isActive])
  @@map("personalization_templates")
}

model TemplateAsset {
  id         String   @id @default(cuid())
  templateId String   @map("template_id")
  assetType  String   @map("asset_type") // BACKGROUND, DECORATION, LOGO, CUT_LINE_SVG
  fileName   String   @map("file_name")
  filePath   String   @map("file_path") // ścieżka relatywna w storage
  fileSize   Int      @map("file_size")
  mimeType   String   @map("mime_type")
  metadata   Json? // width, height, originalName
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  template PersonalizationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([assetType])
