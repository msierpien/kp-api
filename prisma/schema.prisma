// Prisma Schema dla systemu personalizacji PrestaShop
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Multi-tenant
// ============================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model Tenant {
  id         String       @id @default(cuid())
  name       String // np. "Kreatywne Papierki"
  slug       String       @unique // np. "kreatywne-papierki"
  status     TenantStatus @default(ACTIVE)
  plan       String       @default("FREE") // FREE, BASIC, PRO, ENTERPRISE
  limitsJson Json?        @map("limits_json") // { max_shops: 5, max_users: 10, max_cases_per_month: 1000 }
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  // Relations
  users               User[]
  shops               Shop[]
  templates           PersonalizationTemplate[]
  emailSettings       EmailSettings[]
  warehouseProducts   WarehouseProduct[]
  warehouseCatalogs   WarehouseCatalog[]
  warehouseDocuments  WarehouseDocument[]
  warehouseBarcodes   WarehouseProductBarcode[]
  shopProductMappings ShopProductMapping[]
  stockSyncLogs       StockSyncLog[]
  shopProductImportLogs ShopProductImportLog[]
  wholesaleProviders  WholesaleProvider[]
  wholesaleMappings   WholesaleProductMapping[]
  wholesaleSyncLogs   WholesaleSyncLog[]

  @@index([status])
  @@index([slug])
  @@map("tenants")
}

// ============================================
// Integracja / Sklepy
// ============================================

enum ShopPlatform {
  PRESTASHOP
  WOOCOMMERCE
  SHOPIFY
  MAGENTO
  MANUAL // Ręczne zamówienia (FB, Instagram, email)
  CUSTOM_API // Niestandardowe integracje API
  OTHER
}

enum IdentifierType {
  SKU // reference w PrestaShop
  INDEX // supplier_reference w PrestaShop
  EAN // ean13 w PrestaShop
}

model Shop {
  id           String       @id @default(cuid())
  tenantId     String       @map("tenant_id")
  name         String
  platform     ShopPlatform @default(PRESTASHOP)
  baseUrl      String       @map("base_url")
  apiKey       String       @default("") @map("api_key") // zaszyfrowane
  apiSecret    String?      @map("api_secret") // zaszyfrowane, opcjonalne
  status       String       @default("ACTIVE") // ACTIVE, INACTIVE
  lastSyncAt   DateTime?    @map("last_sync_at")
  syncInterval Int          @default(30) @map("sync_interval") // interwał synchronizacji w minutach
  syncEnabled  Boolean      @default(true) @map("sync_enabled") // czy auto-sync jest włączony
  configJson   Json?        @map("config_json") // dodatkowa konfiguracja specyficzna dla platformy
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders               Order[]
  syncLogs             SyncLog[]
  personalizedProducts PersonalizedProduct[]
  productMappings      ShopProductMapping[]
  stockSyncLogs        StockSyncLog[]
  productImportLogs    ShopProductImportLog[]

  @@index([tenantId])
  @@index([status])
  @@index([platform])
  @@index([syncEnabled])
  @@map("shops")
}

model PersonalizedProduct {
  id                String         @id @default(cuid())
  shopId            String         @map("shop_id")
  name              String // nazwa produktu dla łatwej identyfikacji
  identifierType    IdentifierType @default(SKU) @map("identifier_type") // SKU, INDEX, EAN
  identifierValue   String         @map("identifier_value") // wartość identyfikatora (np. "INV-KOMUNIA-001")
  externalProductId String?        @map("external_product_id") // ID produktu w PrestaShop (opcjonalne)
  templateId        String         @map("template_id")
  isActive          Boolean        @default(true) @map("is_active")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  shop       Shop                    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  template   PersonalizationTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]

  @@unique([shopId, identifierType, identifierValue])
  @@index([shopId])
  @@index([identifierValue])
  @@index([isActive])
  @@map("personalized_products")
}

// ============================================
// Zamówienia
// ============================================

model Order {
  id              String   @id @default(cuid())
  shopId          String   @map("shop_id")
  externalOrderId String   @map("external_order_id") // ID zamówienia w sklepie
  orderReference  String   @map("order_reference")
  customerEmail   String   @map("customer_email")
  customerName    String?  @map("customer_name")
  language        String   @default("pl")
  currency        String   @default("PLN")
  totalPaid       Decimal  @map("total_paid") @db.Decimal(10, 2)
  createdAtShop   DateTime @map("created_at_shop")
  payloadJson     Json     @map("payload_json") // snapshot całego zamówienia z API sklepu
  syncedAt        DateTime @default(now()) @map("synced_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  shop                 Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items                OrderItem[]
  personalizationCases PersonalizationCase[]
  accessPins           OrderAccessPin[]
  warehouseDocuments   WarehouseDocument[]

  @@unique([shopId, externalOrderId])
  @@index([shopId, orderReference])
  @@index([customerEmail])
  @@map("orders")
}

model OrderItem {
  id                    String   @id @default(cuid())
  orderId               String   @map("order_id")
  externalItemId        String   @map("external_item_id") // ID pozycji w sklepie
  sku                   String
  productNameSnapshot   String   @map("product_name_snapshot")
  quantity              Int
  personalizedProductId String?  @map("personalized_product_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  personalizedProduct PersonalizedProduct? @relation(fields: [personalizedProductId], references: [id], onDelete: SetNull)
  personalizationCase PersonalizationCase?

  @@index([orderId])
  @@index([sku])
  @@index([personalizedProductId])
  @@map("order_items")
}

// ============================================
// Synchronizacja / Logi
// ============================================

model SyncLog {
  id            String    @id @default(cuid())
  shopId        String    @map("shop_id")
  syncType      String    @map("sync_type") // ORDERS, PRODUCTS
  status        String    @default("SUCCESS") // SUCCESS, FAILED, PARTIAL
  ordersFetched Int       @default(0) @map("orders_fetched")
  ordersCreated Int       @default(0) @map("orders_created")
  ordersSkipped Int       @default(0) @map("orders_skipped")
  errorMessage  String?   @map("error_message") @db.Text
  startedAt     DateTime  @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([startedAt])
  @@index([status])
  @@map("sync_logs")
}

// ============================================
// Konfiguracja personalizacji
// ============================================

model PersonalizationTemplate {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  code         String // np. INV_KOMUNIA_01 (unique per tenant)
  name         String
  description  String?
  version      Int      @default(1)
  isActive     Boolean  @default(true) @map("is_active")
  layoutJson   Json?    @map("layout_json") // TemplateLayoutJson - pozycje pól, warstwy, czcionki
  thumbnailUrl String?  @map("thumbnail_url") // URL miniatury szablonu
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  forms                Form[]
  cases                PersonalizationCase[]
  personalizedProducts PersonalizedProduct[]
  templateAssets       TemplateAsset[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([code])
  @@index([isActive])
  @@map("personalization_templates")
}

model TemplateAsset {
  id         String   @id @default(cuid())
  templateId String   @map("template_id")
  assetType  String   @map("asset_type") // BACKGROUND, DECORATION, LOGO, CUT_LINE_SVG
  fileName   String   @map("file_name")
  filePath   String   @map("file_path") // ścieżka relatywna w storage
  fileSize   Int      @map("file_size")
  mimeType   String   @map("mime_type")
  metadata   Json? // width, height, originalName
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  template PersonalizationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([assetType])
  @@map("template_assets")
}

model Form {
  id         String   @id @default(cuid())
  templateId String   @map("template_id")
  name       String
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  template PersonalizationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fields   FormField[]

  @@index([templateId])
  @@map("forms")
}

model FormField {
  id                  String   @id @default(cuid())
  formId              String   @map("form_id")
  key                 String // unikalne w obrębie formularza
  label               String
  type                String // text, textarea, select, checkbox, date, time, repeater, upload
  required            Boolean  @default(false)
  minLength           Int?     @map("min_length")
  maxLength           Int?     @map("max_length")
  pattern             String? // regex
  placeholder         String?
  helpText            String?  @map("help_text")
  defaultValue        String?  @map("default_value")
  optionsJson         Json?    @map("options_json") // dla select
  repeaterGroupKey    String?  @map("repeater_group_key") // np. "guests"
  sortOrder           Int      @default(0) @map("sort_order")
  validationRulesJson Json?    @map("validation_rules_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  form    Form                    @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers PersonalizationAnswer[]

  @@unique([formId, key])
  @@index([formId])
  @@map("form_fields")
}

// ============================================
// Przypadki personalizacji
// ============================================

model PersonalizationCase {
  id                     String    @id @default(cuid())
  orderId                String    @map("order_id")
  orderItemId            String    @unique @map("order_item_id")
  templateId             String    @map("template_id")
  templateVersionFrozen  Int       @map("template_version_frozen")
  status                 String    @default("NEW") // NEW, WAITING_FOR_CUSTOMER, PREVIEW_READY, SUBMITTED, RENDERED, FAILED_RENDER, READY_FOR_PRINT, ARCHIVED
  customerTokenHash      String?   @unique @map("customer_token_hash")
  customerTokenEncrypted String?   @map("customer_token_encrypted") // Zaszyfrowany token (plain text) do pokazania adminom
  tokenActive            Boolean   @default(true) @map("token_active")
  submittedAt            DateTime? @map("submitted_at")
  answersJson            Json?     @map("answers_json")
  layoutOverrides        Json?     @map("layout_overrides")
  validationSummary      Json?     @map("validation_summary") // { errors: [], warnings: [] }
  notesInternal          String?   @map("notes_internal")

  // Email tracking
  emailSentAt   DateTime? @map("email_sent_at") // Kiedy email został wysłany
  emailFailedAt DateTime? @map("email_failed_at") // Kiedy ostatnia próba failed
  emailError    String?   @map("email_error") // Komunikat błędu
  emailAttempts Int       @default(0) @map("email_attempts") // Liczba prób

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order          Order                          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem      OrderItem                      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  template       PersonalizationTemplate        @relation(fields: [templateId], references: [id], onDelete: Restrict)
  answers        PersonalizationAnswer[]
  answerVersions PersonalizationAnswerVersion[]
  renderJobs     RenderJob[]
  assets         Asset[]

  @@index([orderId])
  @@index([status])
  @@index([customerTokenHash])
  @@index([emailSentAt])
  @@map("personalization_cases")
}

model PersonalizationAnswer {
  id        String   @id @default(cuid())
  caseId    String   @map("case_id")
  fieldId   String   @map("field_id")
  valueText String?  @map("value_text") @db.Text
  valueJson Json?    @map("value_json") // dla repeaterów
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  case  PersonalizationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  field FormField           @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([caseId, fieldId])
  @@index([caseId])
  @@map("personalization_answers")
}

model PersonalizationAnswerVersion {
  id          String   @id @default(cuid())
  caseId      String   @map("case_id")
  changedBy   String   @map("changed_by") // CUSTOMER, ADMIN, SYSTEM
  changesJson Json     @map("changes_json") // diff lub snapshot
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")

  case PersonalizationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([createdAt])
  @@map("personalization_answer_versions")
}

// ============================================
// PIN (opcjonalna weryfikacja)
// ============================================

model OrderAccessPin {
  id        String    @id @default(cuid())
  orderId   String    @map("order_id")
  pinHash   String    @map("pin_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([expiresAt])
  @@map("order_access_pins")
}

// ============================================
// Render i pliki (przyszłość)
// ============================================

model RenderJob {
  id          String    @id @default(cuid())
  caseId      String    @map("case_id")
  jobType     String    @map("job_type") // PDF_PRINT, PNG_PREVIEW
  status      String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  attempts    Int       @default(0)
  error       String?   @db.Text
  metadata    Json? // parametry renderowania
  createdAt   DateTime  @default(now()) @map("created_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  case PersonalizationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([status])
  @@index([jobType])
  @@map("render_jobs")
}

model Asset {
  id        String   @id @default(cuid())
  caseId    String   @map("case_id")
  assetType String   @map("asset_type") // PNG_PREVIEW, PDF_PRINT
  filePath  String   @map("file_path") // ścieżka lokalna lub S3
  fileSize  Int      @map("file_size")
  mimeType  String   @map("mime_type")
  metadata  Json? // dodatkowe dane (width, height, generated, etc)
  createdAt DateTime @default(now()) @map("created_at")

  case PersonalizationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([assetType])
  @@map("assets")
}

// ============================================
// Ustawienia Email (SMTP)
// ============================================

model EmailSettings {
  id        String   @id @default(cuid())
  tenantId  String   @unique @map("tenant_id") // jeden EmailSettings per tenant
  host      String
  port      Int
  secure    Boolean  @default(false)
  user      String
  password  String // zaszyfrowane
  fromEmail String   @map("from_email")
  fromName  String?  @map("from_name")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("email_settings")
}

// ============================================
// Automatyzacje (Automation Rules)
// ============================================

model Automation {
  id          String   @id @default(cuid())
  name        String // Nazwa reguły np. "Wyślij email po utworzeniu case"
  description String? // Opcjonalny opis
  trigger     String // CASE_CREATED, CASE_STATUS_CHANGED, CASE_SUBMITTED, CASE_TIME_ELAPSED
  conditions  Json // Warunki w formacie JSON (status, template, shop, etc.)
  actions     Json // Akcje w formacie JSON (send_email, change_status, add_note, webhook)
  isActive    Boolean  @default(true) @map("is_active")
  priority    Int      @default(0) // Kolejność wykonywania (wyższy = wcześniej)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([trigger])
  @@index([isActive])
  @@index([priority])
  @@map("automations")
}

// ============================================
// Użytkownicy admin (MVP)
// ============================================

model User {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         String    @default("ADMIN") // SUPER_ADMIN, ADMIN
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
  @@index([role])
  @@map("users")
}

// ============================================
// MODUŁ MAGAZYNOWY
// ============================================

enum WarehouseDocumentType {
  PZ // Przyjęcie Zewnętrzne (od dostawcy)
  PW // Przyjęcie Wewnętrzne (np. z produkcji)
  WZ // Wydanie Zewnętrzne (do klienta)
  RW // Rozchód Wewnętrzny (zużycie)
}

enum WarehouseDocumentStatus {
  DRAFT // Roboczy — nie wpływa na stany
  CONFIRMED // Zatwierdzony — wpływa na stany
  CANCELLED // Anulowany
}

enum WholesalePlatform {
  CSV_FEED
  XML_FEED
  REST_API
}

model WarehouseProduct {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  catalogId    String   @map("catalog_id")
  sku          String
  name         String
  unit         String   @default("szt")
  description  String?
  purchasePrice Decimal? @map("purchase_price") @db.Decimal(10, 2)
  retailPrice   Decimal? @map("retail_price") @db.Decimal(10, 2)
  currentStock Decimal  @default(0) @map("current_stock") @db.Decimal(10, 3)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant              Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  catalog             WarehouseCatalog          @relation(fields: [catalogId], references: [id], onDelete: Restrict)
  items               WarehouseDocumentItem[]
  barcodes            WarehouseProductBarcode[]
  shopProductMappings ShopProductMapping[]
  stockSyncLogs       StockSyncLog[]
  wholesaleMappings   WholesaleProductMapping[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([catalogId])
  @@index([tenantId, isActive])
  @@map("warehouse_products")
}

model WarehouseCatalog {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  code        String
  name        String
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products WarehouseProduct[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("warehouse_catalogs")
}

model ShopProductMapping {
  id                 String    @id @default(cuid())
  tenantId           String    @map("tenant_id")
  shopId             String    @map("shop_id")
  externalProductId  String    @map("external_product_id")
  externalSku        String    @map("external_sku")
  externalEan        String?   @map("external_ean")
  externalName       String?   @map("external_name")
  externalPrice      Decimal?  @map("external_price") @db.Decimal(10, 2)
  warehouseProductId String?   @map("warehouse_product_id")
  isActive           Boolean   @default(true) @map("is_active")
  lastSyncAt         DateTime? @map("last_sync_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  warehouseProduct WarehouseProduct? @relation(fields: [warehouseProductId], references: [id], onDelete: SetNull)

  @@unique([shopId, externalProductId])
  @@index([tenantId])
  @@index([shopId])
  @@index([warehouseProductId])
  @@index([tenantId, externalSku])
  @@index([tenantId, externalEan])
  @@index([tenantId, isActive])
  @@map("shop_product_mappings")
}

model ShopProductImportLog {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  shopId          String    @map("shop_id")
  status          String    @default("SUCCESS")
  itemsFetched    Int       @default(0) @map("items_fetched")
  mappingsCreated Int       @default(0) @map("mappings_created")
  mappingsUpdated Int       @default(0) @map("mappings_updated")
  skipped         Int       @default(0)
  skippedNoSku    Int       @default(0) @map("skipped_no_sku")
  errorMessage    String?   @map("error_message") @db.Text
  startedAt       DateTime  @default(now()) @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([shopId])
  @@index([status])
  @@index([startedAt])
  @@map("shop_product_import_logs")
}

model WarehouseProductBarcode {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  warehouseProductId String   @map("warehouse_product_id")
  ean                String
  label              String?
  quantityMultiplier Decimal  @default(1) @map("quantity_multiplier") @db.Decimal(10, 3)
  isPrimary          Boolean  @default(false) @map("is_primary")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouseProduct WarehouseProduct        @relation(fields: [warehouseProductId], references: [id], onDelete: Cascade)
  documentItems    WarehouseDocumentItem[]

  @@unique([tenantId, ean])
  @@index([tenantId])
  @@index([warehouseProductId])
  @@index([tenantId, isActive])
  @@map("warehouse_product_barcodes")
}

model WarehouseDocument {
  id                String                  @id @default(cuid())
  tenantId          String                  @map("tenant_id")
  number            String
  type              WarehouseDocumentType
  status            WarehouseDocumentStatus @default(DRAFT)
  date              DateTime                @default(now())
  description       String?
  orderId           String?                 @map("order_id")
  createdByUserId   String?                 @map("created_by_user_id")
  confirmedAt       DateTime?               @map("confirmed_at")
  confirmedByUserId String?                 @map("confirmed_by_user_id")
  cancelledAt       DateTime?               @map("cancelled_at")
  cancelledByUserId String?                 @map("cancelled_by_user_id")
  cancelReason      String?                 @map("cancel_reason") @db.Text
  isAutoGenerated   Boolean                 @default(false) @map("is_auto_generated")
  metadataJson      Json?                   @map("metadata_json")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  tenant Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order?                  @relation(fields: [orderId], references: [id])
  items  WarehouseDocumentItem[]
  stockSyncLogs StockSyncLog[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([tenantId, date])
  @@index([createdByUserId])
  @@index([confirmedByUserId])
  @@index([cancelledByUserId])
  @@index([isAutoGenerated])
  @@map("warehouse_documents")
}

model WarehouseDocumentItem {
  id                 String   @id @default(cuid())
  documentId         String   @map("document_id")
  productId          String   @map("product_id")
  barcodeId          String?  @map("barcode_id")
  quantity           Decimal  @db.Decimal(10, 3)
  unitPrice          Decimal? @map("unit_price") @db.Decimal(10, 2)
  scannedEan         String?  @map("scanned_ean")
  baseQuantity       Decimal? @map("base_quantity") @db.Decimal(10, 3)
  quantityMultiplier Decimal? @map("quantity_multiplier") @db.Decimal(10, 3)
  notes              String?

  document WarehouseDocument        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product  WarehouseProduct         @relation(fields: [productId], references: [id])
  barcode  WarehouseProductBarcode? @relation(fields: [barcodeId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([productId])
  @@index([barcodeId])
  @@map("warehouse_document_items")
}

model StockSyncLog {
  id                 String    @id @default(cuid())
  tenantId           String    @map("tenant_id")
  warehouseProductId String    @map("warehouse_product_id")
  shopId             String    @map("shop_id")
  triggeredBy        String    @map("triggered_by")
  documentId         String?   @map("document_id")
  stockBefore        Decimal?  @map("stock_before") @db.Decimal(10, 3)
  stockAfter         Decimal   @map("stock_after") @db.Decimal(10, 3)
  status             String    @default("PENDING")
  errorMessage       String?   @map("error_message") @db.Text
  attemptCount       Int       @default(0) @map("attempt_count")
  syncedAt           DateTime? @map("synced_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouseProduct WarehouseProduct   @relation(fields: [warehouseProductId], references: [id], onDelete: Cascade)
  shop             Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  document         WarehouseDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([warehouseProductId])
  @@index([shopId])
  @@index([status])
  @@index([createdAt])
  @@map("stock_sync_logs")
}

model WholesaleProvider {
  id          String            @id @default(cuid())
  tenantId    String            @map("tenant_id")
  name        String
  platform    WholesalePlatform @default(CSV_FEED)
  feedUrl     String            @map("feed_url") @db.Text
  configJson  Json?             @map("config_json")
  syncEnabled Boolean           @default(true) @map("sync_enabled")
  isActive    Boolean           @default(true) @map("is_active")
  lastSyncAt  DateTime?         @map("last_sync_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  tenant   Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mappings WholesaleProductMapping[]
  syncLogs WholesaleSyncLog[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, syncEnabled])
  @@map("wholesale_providers")
}

model WholesaleProductMapping {
  id                 String    @id @default(cuid())
  tenantId           String    @map("tenant_id")
  providerId         String    @map("provider_id")
  externalSku        String    @map("external_sku")
  externalEan        String?   @map("external_ean")
  externalName       String?   @map("external_name")
  externalCategory   String?   @map("external_category")
  warehouseProductId String?   @map("warehouse_product_id")
  lastKnownStock     Decimal?  @map("last_known_stock") @db.Decimal(10, 3)
  lastKnownPrice     Decimal?  @map("last_known_price") @db.Decimal(10, 2)
  payloadJson        Json?     @map("payload_json")
  isActive           Boolean   @default(true) @map("is_active")
  lastSyncAt         DateTime? @map("last_sync_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider         WholesaleProvider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  warehouseProduct WarehouseProduct?  @relation(fields: [warehouseProductId], references: [id], onDelete: SetNull)

  @@unique([providerId, externalSku])
  @@index([tenantId])
  @@index([providerId])
  @@index([warehouseProductId])
  @@index([tenantId, externalSku])
  @@index([tenantId, isActive])
  @@map("wholesale_product_mappings")
}

model WholesaleSyncLog {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  providerId      String    @map("provider_id")
  status          String    @default("SUCCESS")
  itemsFetched    Int       @default(0) @map("items_fetched")
  mappingsCreated Int       @default(0) @map("mappings_created")
  mappingsUpdated Int       @default(0) @map("mappings_updated")
  skipped         Int       @default(0)
  errorMessage    String?   @map("error_message") @db.Text
  startedAt       DateTime  @default(now()) @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider WholesaleProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([providerId])
  @@index([status])
  @@index([startedAt])
  @@map("wholesale_sync_logs")
}
