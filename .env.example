# Environment
NODE_ENV=development

# API
API_PORT=3001
API_HOST=0.0.0.0

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=personalization
DB_USER=postgres
DB_PASSWORD=postgres

# Prisma Database URL (format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA)
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/personalization?schema=public"

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis

# JWT Secrets (CHANGE IN PRODUCTION!)
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (MUST BE EXACTLY 32 CHARACTERS - CHANGE IN PRODUCTION!)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook
WEBHOOK_SECRET=your-webhook-secret-shared-with-prestashop

# Email (SMTP)
# For dev: use MailHog (SMTP_HOST=localhost, SMTP_PORT=1025)
# For production: use real SMTP server
AUTO_SEND_EMAILS=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@kreatywne-papierki.pl

# Adminer
ADMINER_PORT=8081

# Application URLs
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
PUBLIC_PORTAL_BASE_URL=http://localhost:3001/public
