<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Great+Vibes&family=Inter:wght@300;400;500&display=swap');

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      width: 100%;
      height: 100%;
      font-family: 'Inter', sans-serif;
      background: #fff;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    .invitation {
      width: 100%;
      height: 100%;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 50px 35px;
      background: linear-gradient(180deg, #fefdfb 0%, #fff 30%, #fff 70%, #fefdfb 100%);
    }

    /* Złota ramka z podwójną linią */
    .border-outer {
      position: absolute;
      top: 20px;
      left: 20px;
      right: 20px;
      bottom: 20px;
      border: 2px solid #c9a84c;
    }

    .border-inner {
      position: absolute;
      top: 28px;
      left: 28px;
      right: 28px;
      bottom: 28px;
      border: 1px solid #c9a84c44;
    }

    /* Narożne ornamenty */
    .ornament {
      position: absolute;
      width: 60px;
      height: 60px;
      opacity: 0.7;
    }

    .ornament-tl { top: 35px; left: 35px; transform: rotate(0deg); }
    .ornament-tr { top: 35px; right: 35px; transform: rotate(90deg); }
    .ornament-bl { bottom: 35px; left: 35px; transform: rotate(-90deg); }
    .ornament-br { bottom: 35px; right: 35px; transform: rotate(180deg); }

    .ornament svg {
      width: 100%;
      height: 100%;
      fill: #c9a84c;
    }

    /* Krzyż/hostia na górze */
    .header-icon {
      margin-top: 30px;
      margin-bottom: 15px;
      width: 60px;
      height: 60px;
    }

    .header-icon svg {
      width: 100%;
      height: 100%;
      fill: #c9a84c;
    }

    /* Tytuł główny */
    .main-title {
      font-family: 'Playfair Display', serif;
      font-size: 14px;
      font-weight: 500;
      color: #666;
      text-transform: uppercase;
      letter-spacing: 6px;
      margin-bottom: 8px;
    }

    /* Pierwsza Komunia Święta */
    .communion-title {
      font-family: 'Great Vibes', cursive;
      font-size: 38px;
      color: #c9a84c;
      margin-bottom: 25px;
    }

    /* Linia dekoracyjna */
    .separator {
      width: 180px;
      height: 1px;
      background: linear-gradient(90deg, transparent 0%, #c9a84c 20%, #c9a84c 80%, transparent 100%);
      margin: 15px 0;
    }

    /* Imię dziecka */
    .child-name {
      font-family: 'Playfair Display', serif;
      font-size: 32px;
      font-weight: 600;
      color: #333;
      text-align: center;
      margin: 20px 0;
      text-transform: capitalize;
    }

    /* Tekst zaproszenia */
    .invitation-text {
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      font-weight: 400;
      color: #666;
      text-align: center;
      line-height: 1.9;
      max-width: 85%;
      margin: 15px 0;
    }

    /* Sekcja daty */
    .date-section {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin: 20px 0;
    }

    .date-label {
      font-family: 'Inter', sans-serif;
      font-size: 10px;
      font-weight: 500;
      color: #999;
      text-transform: uppercase;
      letter-spacing: 3px;
      margin-bottom: 5px;
    }

    .date-value {
      font-family: 'Playfair Display', serif;
      font-size: 20px;
      font-weight: 500;
      color: #333;
    }

    .time-value {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 400;
      color: #555;
      margin-top: 5px;
    }

    /* Miejsce */
    .venue-section {
      text-align: center;
      margin: 15px 0;
    }

    .venue-name {
      font-family: 'Playfair Display', serif;
      font-size: 16px;
      font-weight: 600;
      color: #333;
      margin-bottom: 5px;
    }

    .venue-address {
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 400;
      color: #777;
      line-height: 1.6;
    }

    /* Przyjęcie */
    .reception-section {
      background: #f9f7f2;
      padding: 15px 25px;
      border-radius: 4px;
      margin: 20px 0;
      text-align: center;
    }

    .reception-label {
      font-family: 'Inter', sans-serif;
      font-size: 10px;
      font-weight: 500;
      color: #999;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 8px;
    }

    .reception-venue {
      font-family: 'Playfair Display', serif;
      font-size: 14px;
      font-weight: 500;
      color: #444;
    }

    .reception-time {
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      color: #666;
      margin-top: 5px;
    }

    /* Dodatkowe info */
    .additional-info {
      font-family: 'Inter', sans-serif;
      font-size: 11px;
      font-weight: 400;
      color: #999;
      text-align: center;
      font-style: italic;
      margin-top: 15px;
      max-width: 75%;
    }

    /* Podpis rodziny */
    .signature {
      font-family: 'Great Vibes', cursive;
      font-size: 24px;
      color: #555;
      margin-top: 25px;
    }

    /* Watermark */
    .watermark {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) rotate({{watermark.angle}}deg);
      font-family: 'Inter', sans-serif;
      font-size: {{watermark.fontSize}}px;
      font-weight: 700;
      color: #999;
      opacity: {{watermark.opacity}};
      pointer-events: none;
      white-space: nowrap;
      z-index: 100;
    }
  </style>
</head>
<body>
  <div class="invitation">
    <!-- Ramki -->
    <div class="border-outer"></div>
    <div class="border-inner"></div>

    <!-- Ornamenty narożne -->
    <div class="ornament ornament-tl">
      <svg viewBox="0 0 50 50">
        <path d="M0 0 L50 0 L50 5 L5 5 L5 50 L0 50 Z M10 10 Q25 10 25 25 Q25 10 40 10 L40 15 Q30 15 25 20 Q20 15 10 15 Z"/>
      </svg>
    </div>
    <div class="ornament ornament-tr">
      <svg viewBox="0 0 50 50">
        <path d="M0 0 L50 0 L50 5 L5 5 L5 50 L0 50 Z M10 10 Q25 10 25 25 Q25 10 40 10 L40 15 Q30 15 25 20 Q20 15 10 15 Z"/>
      </svg>
    </div>
    <div class="ornament ornament-bl">
      <svg viewBox="0 0 50 50">
        <path d="M0 0 L50 0 L50 5 L5 5 L5 50 L0 50 Z M10 10 Q25 10 25 25 Q25 10 40 10 L40 15 Q30 15 25 20 Q20 15 10 15 Z"/>
      </svg>
    </div>
    <div class="ornament ornament-br">
      <svg viewBox="0 0 50 50">
        <path d="M0 0 L50 0 L50 5 L5 5 L5 50 L0 50 Z M10 10 Q25 10 25 25 Q25 10 40 10 L40 15 Q30 15 25 20 Q20 15 10 15 Z"/>
      </svg>
    </div>

    <!-- Ikona hostii/krzyża -->
    <div class="header-icon">
      <svg viewBox="0 0 100 100">
        <!-- Hostia z krzyżem -->
        <circle cx="50" cy="50" r="40" fill="none" stroke="currentColor" stroke-width="2"/>
        <circle cx="50" cy="50" r="35" fill="none" stroke="currentColor" stroke-width="1" opacity="0.5"/>
        <path d="M50 20 L50 80 M30 50 L70 50" stroke="currentColor" stroke-width="3"/>
        <!-- Promienie -->
        <path d="M50 10 L50 15 M50 85 L50 90 M10 50 L15 50 M85 50 L90 50" stroke="currentColor" stroke-width="2"/>
        <path d="M22 22 L26 26 M74 74 L78 78 M22 78 L26 74 M74 26 L78 22" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </div>

    <!-- Tytuł -->
    <div class="main-title">Zaproszenie na</div>
    <div class="communion-title">Pierwszą Komunię Świętą</div>

    <div class="separator"></div>

    <!-- Imię dziecka -->
    {{#if childName}}
    <div class="child-name">{{capitalize childName}}</div>
    {{/if}}

    <!-- Tekst zaproszenia -->
    {{#if invitationText}}
    <p class="invitation-text">{{{multiline invitationText}}}</p>
    {{else}}
    <p class="invitation-text">
      Serdecznie zapraszamy na uroczystość<br>
      przyjęcia Pierwszej Komunii Świętej,<br>
      która odbędzie się:
    </p>
    {{/if}}

    <!-- Data i godzina -->
    <div class="date-section">
      {{#if date}}
      <span class="date-label">Data</span>
      <span class="date-value">{{#if formatDateEnabled}}{{formatDate date}}{{else}}{{date}}{{/if}}</span>
      {{/if}}
      {{#if time}}
      <span class="time-value">godz. {{time}}</span>
      {{/if}}
    </div>

    <!-- Kościół -->
    {{#if churchName}}
    <div class="venue-section">
      <div class="venue-name">{{churchName}}</div>
      {{#if churchAddress}}
      <div class="venue-address">{{{multiline churchAddress}}}</div>
      {{/if}}
    </div>
    {{/if}}

    <div class="separator"></div>

    <!-- Przyjęcie (opcjonalne) -->
    {{#if receptionVenue}}
    <div class="reception-section">
      <div class="reception-label">Po mszy świętej zapraszamy na przyjęcie</div>
      <div class="reception-venue">{{receptionVenue}}</div>
      {{#if receptionTime}}
      <div class="reception-time">od godz. {{receptionTime}}</div>
      {{/if}}
    </div>
    {{/if}}

    <!-- Dodatkowe informacje -->
    {{#if additionalInfo}}
    <p class="additional-info">{{{multiline additionalInfo}}}</p>
    {{/if}}

    <!-- Podpis -->
    {{#if signature}}
    <div class="signature">{{signature}}</div>
    {{/if}}

    <!-- Watermark -->
    {{#if watermark}}
    <div class="watermark">{{watermark.text}}</div>
    {{/if}}
  </div>
</body>
</html>
